{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "philiprehberger/pennant",
    "description": "Pennant SDK — feature flag client with deterministic local bucketing, snapshot bootstrap, and Laravel integration.",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Philip Rehberger"
        }
    ],
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0 || ^12.0",
        "guzzlehttp/guzzle": "^7.0"
    },
    "autoload": {
        "psr-4": {
            "Pennant\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Pennant\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Pennant\\Laravel\\PennantServiceProvider"
            ],
            "aliases": {
                "Pennant": "Pennant\\Laravel\\PennantFacade"
            }
        }
    },
    "minimum-stability": "stable"
}
