{
  "name": "@philiprehberger/pennant-react",
  "version": "0.1.0",
  "description": "React adapter for Pennant — useFlag hooks + PennantProvider, with selective re-render via useSyncExternalStore.",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/philiprehberger/pennant.git",
    "directory": "sdks/react"
  },
  "license": "MIT",
  "author": "Philip Rehberger",
  "engines": {
    "node": ">=22"
  },
  "peerDependencies": {
    "@philiprehberger/pennant": "^0.1.0",
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@philiprehberger/pennant": "file:../typescript",
    "@testing-library/react": "^16.0.0",
    "@types/node": "^22.7.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "happy-dom": "^15.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
